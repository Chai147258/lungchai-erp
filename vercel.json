{
  "projectSettings": {
    "framework": "static",
    "buildCommand": "echo 'Static HTML deployment'",
    "outputDirectory": "public"
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_SUPABASE_URL": "@supabase_url",
    "REACT_APP_SUPABASE_KEY": "@supabase_key"
  },
  "buildOutputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false
}
